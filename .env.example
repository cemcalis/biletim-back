# Local Development Environment (.env)
# Copy this file to .env and customize for your setup

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3010
API_PREFIX=api

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=bustour_user
DB_PASSWORD=bustour_password
DB_NAME=bustour_db
DB_ROOT_PASSWORD=rootpassword

# Frontend Configuration  
NEXT_PUBLIC_API_URL=http://localhost:3010/api

# Authentication (if implementing JWT)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=24h

# Email Configuration (if implementing email)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Logging
LOG_LEVEL=debug

# Database Synchronization (dev only, disable in production)
DB_SYNCHRONIZE=true
DB_LOGGING=true
